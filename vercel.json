{
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "https://delivry-backend.vercel.app/auth/:path*" },
    { "source": "/api/admin/:path*", "destination": "https://delivry-backend.vercel.app/admin/:path*" },
    { "source": "/api/drivers/:path*", "destination": "https://delivry-backend.vercel.app/drivers/:path*" },
    { "source": "/api/driver/:path*", "destination": "https://delivry-backend.vercel.app/driver/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
